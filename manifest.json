{
  "manifest_version": 3,
  "name": "CleanFeed",
  "version": "2.0",
  "description": "Limpia YouTube (Shorts/feed) y X/Twitter (Para ti, panel, sidebar).",
  "permissions": ["tabs", "storage", "declarativeNetRequest"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.tiktok.com/*",
    "*://*.instagram.com/*",
    "*://*.x.com/*",
    "*://*.twitter.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["block.html", "block.js", "shared.js", "logo.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "CleanFeed",
    "default_icon": "logo.png"
  },
  "icons": {
    "128": "logo.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["video.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "css": ["hide.css"],
      "js": ["content.js", "youtube.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.x.com/*", "*://*.twitter.com/*"],
      "js": ["twitter.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.instagram.com/*"],
      "js": ["instagram.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.tiktok.com/*"],
      "js": ["tiktok.js"],
      "run_at": "document_start"
    }
  ]
}
