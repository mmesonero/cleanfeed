{
  "manifest_version": 3,
  "name": "CleanFeed",
  "version": "2.0",
  "description": "Remove distractions across YouTube, X, Instagram and TikTok. Toggle per-platform filters or hard-block entire sites.",
  "permissions": ["tabs", "storage", "declarativeNetRequest"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.tiktok.com/*",
    "*://*.instagram.com/*",
    "*://*.x.com/*",
    "*://*.twitter.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["ui/block.html", "ui/block.js", "shared.js", "assets/logo.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "ui/popup.html",
    "default_title": "CleanFeed",
    "default_icon": "assets/logo.png"
  },
  "icons": {
    "128": "assets/logo.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/skip-world.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/video.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "css": ["content/hide.css"],
      "js": ["content/content.js", "content/youtube.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.x.com/*", "*://*.twitter.com/*"],
      "js": ["content/twitter.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.instagram.com/*"],
      "js": ["content/instagram.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.tiktok.com/*"],
      "js": ["content/tiktok.js"],
      "run_at": "document_start"
    }
  ]
}
